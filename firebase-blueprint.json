{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name", "email"]
    },
    "TripConfig": {
      "title": "TripConfig",
      "description": "Configuration for the couple's trip",
      "type": "object",
      "properties": {
        "destination": { "type": "string" },
        "goalAmount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["destination", "goalAmount"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "A deposit made by a user",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "action": { "type": "string" },
        "who": { "type": "string" },
        "whoName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "action", "who", "whoName", "createdAt"]
    },
    "BingoStat": {
      "title": "BingoStat",
      "description": "Stats for bingo actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "count": { "type": "number" }
      },
      "required": ["action", "count"]
    },
    "PinboardLink": {
      "title": "PinboardLink",
      "description": "A link or inspiration pinned to the dream board",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "title", "createdAt"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Completed pot achievements",
      "type": "object",
      "properties": {
        "destination": { "type": "string" },
        "amount": { "type": "number" },
        "goalAmount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["destination", "amount", "goalAmount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/casais/{casalId}/trip_config/main": {
      "schema": { "$ref": "#/entities/TripConfig" },
      "description": "The single trip configuration for the couple"
    },
    "/casais/{casalId}/deposits/{depositId}": {
      "schema": { "$ref": "#/entities/Deposit" },
      "description": "All deposits made towards the trip"
    },
    "/casais/{casalId}/pinboard_links/{linkId}": {
      "schema": { "$ref": "#/entities/PinboardLink" },
      "description": "Links and inspirations added to the dream board"
    },
    "/casais/{casalId}/achievements/{achievementId}": {
      "schema": { "$ref": "#/entities/Achievement" },
      "description": "Historical records of completed pots"
    },
    "/casais/{casalId}/bingo_stats/{actionId}": {
      "schema": { "$ref": "#/entities/BingoStat" },
      "description": "Aggregated stats for each bingo action"
    }
  }
}
