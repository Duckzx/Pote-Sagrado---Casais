rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCasalMember(casalId) {
      return isAuthenticated() && (
        casalId == 'casal_' + request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.casalId == casalId)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['theme']) &&
             data.theme is string && data.theme.size() < 50 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    function isValidTripConfig(data) {
      return data.keys().hasAll(['destination', 'goalAmount']) &&
             data.destination is string && data.destination.size() < 200 &&
             data.goalAmount is number && data.goalAmount >= 0;
    }

    function isValidDeposit(data) {
      return data.keys().hasAll(['amount', 'who', 'createdAt']) &&
             data.amount is number && data.amount > 0 &&
             data.who == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['destination', 'amount', 'goalAmount', 'createdAt']) &&
             data.destination is string && data.amount is number &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Casais Nested Collections
    match /casais/{casalId} {
      allow read: if isCasalMember(casalId);
      
      // Configuration
      match /trip_config/main {
        allow read: if isCasalMember(casalId);
        allow write: if isCasalMember(casalId) && isValidTripConfig(request.resource.data);
      }
      
      // Deposits / Savings
      match /deposits/{depositId} {
        allow read: if isCasalMember(casalId);
        allow create: if isCasalMember(casalId) && isValidDeposit(request.resource.data);
        allow update: if isCasalMember(casalId) && resource.data.who == request.auth.uid;
        allow delete: if isCasalMember(casalId);
      }
      
      // Achievements
      match /achievements/{achievementId} {
        allow read: if isCasalMember(casalId);
        allow create: if isCasalMember(casalId) && isValidAchievement(request.resource.data);
        allow delete: if isCasalMember(casalId);
      }
      
      // Pinboard
      match /pinboard_links/{linkId} {
        allow read: if isCasalMember(casalId);
        allow create: if isCasalMember(casalId);
        allow delete: if isCasalMember(casalId);
      }
      
      // Custom Dates (CheapDateModal)
      match /customDates/{dateId} {
        allow read: if isCasalMember(casalId);
        allow create: if isCasalMember(casalId);
        allow delete: if isCasalMember(casalId);
      }

      // Gallery
      match /gallery/{photoId} {
        allow read: if isCasalMember(casalId);
        allow create: if isCasalMember(casalId);
        allow delete: if isCasalMember(casalId);
      }
    }

    // Legacy support (read-only for migration)
    match /deposits/{id} { allow read, delete: if isAuthenticated(); }
    match /achievements/{id} { allow read, delete: if isAuthenticated(); }
    match /pinboard_links/{id} { allow read, delete: if isAuthenticated(); }
    match /gallery/{id} { allow read, delete: if isAuthenticated(); }
  }
}
